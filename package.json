{
  "name": "lifeverse",
  "version": "0.1.0",
  "private": true,
  "description": "LifeVerse — a generational life-simulation game.",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=20.11.0"
  },
  "workspaces": [
    "packages/shared",
    "packages/server",
    "packages/client"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "typecheck": "tsc -b --verbose",
    "dev": "npm run dev --workspaces --if-present",
    "dev:shared": "npm run dev --workspace @lifeverse/shared",
    "dev:server": "npm run dev --workspace @lifeverse/server",
    "dev:client": "npm run dev --workspace @lifeverse/client",
    "db:migrate": "npm run db:migrate --workspace @lifeverse/server",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"packages/**/src/**/*.{ts,tsx}\""
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "eslint": "^8.57.1",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
