# Dependencies
node_modules/

# Build output
dist/
*.tsbuildinfo

# Environment
.env
.env.local
.env.*.local

# SQLite database files (runtime data — never commit saves)
*.db
*.db-shm
*.db-wal
# The server's runtime DB directory only — NOT source folders named "data"
# (e.g. packages/shared/src/data, which holds the game catalogs).
/packages/server/data/

# Logs
logs/
*.log
npm-debug.log*

# Editor / OS
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db

# Local Claude Code settings (personal, not shared)
.claude/settings.local.json

# Test / coverage
coverage/

# Local tooling binaries (e.g. cloudflared tunnel for sharing test builds)
tools/
*.exe
