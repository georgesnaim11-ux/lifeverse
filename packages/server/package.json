{
  "name": "@lifeverse/server",
  "version": "0.1.0",
  "private": true,
  "description": "LifeVerse game server — simulation engine, persistence, and API.",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -b && node scripts/copy-assets.mjs",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "clean": "tsc -b --clean"
  },
  "dependencies": {
    "@lifeverse/shared": "*",
    "better-sqlite3": "^11.3.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.16.10",
    "tsx": "^4.19.1"
  }
}
