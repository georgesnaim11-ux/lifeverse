# LifeVerse — root environment template.
# Copy to `.env` (root) and/or packages/server/.env and adjust as needed.
# The server reads its config via packages/server/src/config/env.ts (Zod-validated).

# Runtime mode: development | test | production
NODE_ENV=development

# HTTP port the Express server listens on
PORT=4000

# Comma-separated list of allowed CORS origins (client dev server, etc.)
CORS_ORIGIN=http://localhost:5173

# Absolute or relative path to the SQLite database file.
# Relative paths resolve from the server package root.
DATABASE_PATH=./data/lifeverse.db

# Log verbosity: debug | info | warn | error
LOG_LEVEL=debug
